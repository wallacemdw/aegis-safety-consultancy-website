        </div>
        <div class="contact-item">
          <div class="contact-item-icon">📧</div>
          <div class="contact-item-text">
            <strong>Email</strong>
            <p>Matt.Wallace@Aegissafetyconsultancy.com.au</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon">📍</div>
          <div class="contact-item-text">
            <strong>Location</strong>
            <p>Perth, Western Australia</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

